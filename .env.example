# ============================================================
# DeltaUptime — пример конфигурации. Скопируй в .env и заполни.
# Реальный .env НЕ коммитится (см. .gitignore).
# ============================================================

# --- Control Plane ---
APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_PANEL_URL=https://panel.localhost
PUBLIC_STATUS_URL=https://status.localhost

# --- PostgreSQL (источник истины) ---
POSTGRES_DSN=postgres://uptime:uptime@localhost:5432/uptime?sslmode=disable

# --- ClickHouse (метрики проверок — ПОЗДНЯЯ СТАДИЯ, на старте не нужен) ---
# На старте метрики проверок хранятся в PostgreSQL. Раскомментировать при переезде.
# CLICKHOUSE_DSN=clickhouse://localhost:9000/uptime

# --- Redis (cache / locks / presence) ---
REDIS_URL=redis://localhost:6379/0

# --- NATS JetStream (шина задач и событий) ---
NATS_URL=nats://localhost:4222

# --- Auth ---
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# --- Agent enrollment ---
AGENT_ENROLLMENT_SECRET=change_me_enrollment

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Observability ---
# Prometheus/Grafana/OTLP-экспорт — поздняя стадия. На старте достаточно логов.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
